
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<meta name="theme-color" content="#06141B"/>
<title>MovePA — Mobilidade em Paulo Afonso</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500..800&family=Archivo:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<!--
  ════════════════════════════════════════════════════════════════
  PERSONALIZAR PARA CADA MOTORISTA (Ricardo, leia aqui!)
  ════════════════════════════════════════════════════════════════
  Pra vender este app pra um motorista individual, troque só estes
  4 valores no início do <script>, lá no final do arquivo:

    NOME_MOTORISTA   -> nome do motorista
    TELEFONE_MOTORISTA -> número de WhatsApp/ligação (com DDD)
    CARRO_MOTORISTA  -> modelo e cor do carro
    PLACA_MOTORISTA  -> placa do carro

  Depois suba esse arquivo com um link novo pra cada motorista.
  Tudo o resto do app já funciona igual, sem precisar tocar em nada.

  GOOGLE MAPS (opcional, mais abaixo no <script>):
  1. Crie conta grátis em https://console.cloud.google.com
  2. Ative "Maps JavaScript API" e gere uma chave
  3. Cole a chave em GOOGLE_MAPS_API_KEY
  Sem a chave, o mapa ilustrativo funciona normalmente.
  ════════════════════════════════════════════════════════════════
-->
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{
  --rio-fundo:#06141B;
  --rio-painel:#0D2430;
  --rio-card:#122E3B;
  --rio-card2:#173a49;
  --linha:#21495a;
  --turbina:#0FA3B1;
  --turbina-clara:#5FD0DC;
  --luz:#F4A340;
  --luz-clara:#FFC773;
  --texto:#EAF2F3;
  --discreto:#7FA0A8;
  --alerta:#E2574C;
  --sucesso:#3FBF8F;
  --serif:'Fraunces',serif;
  --sans:'Archivo',sans-serif;
}
html,body{height:100%;background:var(--rio-fundo);color:var(--texto);overflow:hidden;font-family:var(--sans)}
#app{
  max-width:430px;margin:0 auto;height:100vh;display:flex;flex-direction:column;
  position:relative;overflow:hidden;background:var(--rio-fundo);
}
.serif{font-family:var(--serif)}

/* ── textura de fundo: linhas de energia/rio, sutil e contínua ── */
#riverlines{position:absolute;inset:0;z-index:0;opacity:.5;pointer-events:none}

/* ── HEADER ── */
#header{padding:18px 20px 14px;display:flex;align-items:center;gap:12px;flex-shrink:0;position:relative;z-index:5}
.back-btn{background:var(--rio-card);border:1px solid var(--linha);width:34px;height:34px;border-radius:10px;color:var(--luz);font-size:18px;cursor:pointer;display:none;align-items:center;justify-content:center;flex-shrink:0}
.brandmark{width:40px;height:40px;border-radius:11px;background:linear-gradient(160deg,var(--turbina) 0%,var(--rio-painel) 100%);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;overflow:hidden;border:1px solid rgba(95,208,220,.25)}
.brandmark::after{content:'';position:absolute;inset:0;background:linear-gradient(115deg,transparent 30%,rgba(244,163,64,.5) 50%,transparent 70%);transform:translateX(-100%);animation:sheen 4.5s ease-in-out infinite}
@keyframes sheen{0%,60%{transform:translateX(-120%)}100%{transform:translateX(120%)}}
.brandmark svg{width:21px;height:21px;position:relative;z-index:1}
.title-block{flex:1;min-width:0}
.title-main{font-family:var(--serif);font-size:19px;font-weight:700;letter-spacing:-.2px;line-height:1}
.title-sub{font-size:10.5px;color:var(--discreto);margin-top:2px;letter-spacing:.3px}
.status-pill{display:flex;align-items:center;gap:6px;background:var(--rio-card);border:1px solid var(--linha);border-radius:20px;padding:6px 12px;font-size:10.5px;font-weight:600;color:var(--sucesso);flex-shrink:0}
.pulse{width:6px;height:6px;border-radius:50%;background:var(--sucesso);box-shadow:0 0 0 0 rgba(63,191,143,.6);animation:pulse 1.8s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(63,191,143,.5)}70%{box-shadow:0 0 0 6px rgba(63,191,143,0)}100%{box-shadow:0 0 0 0 rgba(63,191,143,0)}}

/* ── BODY ── */
#body{flex:1;overflow-y:auto;overflow-x:hidden;padding:4px 20px 100px;position:relative;z-index:2;scroll-behavior:smooth}
#body::-webkit-scrollbar{width:3px}
#body::-webkit-scrollbar-thumb{background:var(--linha);border-radius:4px}

/* ── NAV ── */
#nav{position:absolute;bottom:0;left:0;right:0;display:flex;background:rgba(13,36,48,.94);backdrop-filter:blur(16px);border-top:1px solid var(--linha);z-index:50;padding-bottom:env(safe-area-inset-bottom)}
.nav-btn{flex:1;background:none;border:none;cursor:pointer;padding:12px 4px 10px;display:flex;flex-direction:column;align-items:center;gap:5px;color:var(--discreto);font-size:10px;font-weight:600;transition:color .2s;font-family:var(--sans)}
.nav-btn.active{color:var(--luz)}
.nav-btn .ni{font-size:18px;line-height:1;transition:transform .25s}
.nav-btn.active .ni{transform:translateY(-2px)}
.nav-rule{width:16px;height:2px;border-radius:2px;background:var(--luz);opacity:0;transition:opacity .2s;margin-top:-1px}
.nav-btn.active .nav-rule{opacity:1}

/* ── TELAS ── */
.tela{display:none;animation:rise .32s cubic-bezier(.16,1,.3,1)}
.tela.ativa{display:block}
@keyframes rise{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* ── CARD BASE ── */
.card{background:var(--rio-card);border:1px solid var(--linha);border-radius:18px;padding:18px;margin-bottom:14px;position:relative}

/* ── HERO ── */
.hero{border-radius:22px;padding:30px 22px 26px;margin-bottom:18px;position:relative;overflow:hidden;
  background:linear-gradient(165deg,var(--rio-painel) 0%, #081A22 70%);border:1px solid var(--linha);}
.hero-rule{width:34px;height:3px;background:var(--luz);border-radius:3px;margin-bottom:16px}
.hero-eyebrow{font-size:11px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--turbina-clara);margin-bottom:6px;display:flex;align-items:center;gap:7px}
.hero-h1{font-family:var(--serif);font-size:33px;font-weight:600;line-height:1.08;letter-spacing:-.5px;margin-bottom:10px}
.hero-h1 em{font-style:italic;color:var(--luz);font-weight:600}
.hero-sub{font-size:13.5px;color:var(--discreto);max-width:250px;line-height:1.6}
.hero-meter{display:flex;gap:0;margin-top:22px;border-top:1px solid var(--linha);padding-top:16px}
.meter-item{flex:1;border-right:1px solid var(--linha)}
.meter-item:last-child{border-right:none}
.meter-n{font-family:var(--serif);font-size:21px;font-weight:700;color:var(--texto)}
.meter-n span{font-size:12px;color:var(--turbina-clara)}
.meter-l{font-size:9.5px;color:var(--discreto);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}

/* ── ACTION GRID ── */
.action-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-bottom:20px}
.action-card{border-radius:16px;padding:19px 15px;cursor:pointer;border:1px solid var(--linha);background:var(--rio-card);text-align:left;transition:transform .15s,border-color .2s}
.action-card:active{transform:scale(.96)}
.action-num{font-family:var(--serif);font-size:11px;color:var(--discreto);letter-spacing:.5px;margin-bottom:10px;display:block}
.action-label{font-size:14px;font-weight:700;letter-spacing:-.1px;margin-bottom:3px}
.action-sub{font-size:11px;color:var(--discreto)}
.ac-urbana:hover,.ac-urbana:active{border-color:var(--turbina)}
.ac-inter:hover,.ac-inter:active{border-color:var(--luz)}
.ac-gps:hover,.ac-gps:active{border-color:var(--sucesso)}
.ac-chat:hover,.ac-chat:active{border-color:var(--turbina-clara)}

/* ── SECTION ── */
.sec-head{display:flex;align-items:baseline;justify-content:space-between;margin:6px 0 13px}
.sec-title{font-family:var(--serif);font-size:16px;font-weight:600}
.sec-link{font-size:11.5px;color:var(--turbina-clara);font-weight:600;cursor:pointer}

/* ── DEST LIST ── */
.dest-item{display:flex;align-items:center;gap:13px;padding:13px 2px;border-bottom:1px solid var(--linha);cursor:pointer}
.dest-item:last-child{border-bottom:none}
.dest-mark{width:8px;height:8px;border-radius:50%;background:var(--turbina);flex-shrink:0}
.dest-name{font-size:14px;font-weight:600}
.dest-time{font-size:10.5px;color:var(--discreto);margin-top:1px}
.dest-arrow{margin-left:auto;color:var(--luz);font-size:17px;font-family:var(--serif)}

/* ── DRIVER PROMO ── */
.driver-promo{background:linear-gradient(165deg,rgba(244,163,64,.10),var(--rio-card));border-color:rgba(244,163,64,.3)}
.driver-promo-label{font-family:var(--serif);font-size:15px;font-weight:600;margin-bottom:8px}
.driver-promo-text{font-size:12.5px;color:var(--discreto);line-height:1.6;margin-bottom:15px}

/* ── CHIPS ── */
.chip{border-radius:20px;padding:5px 12px;font-size:10.5px;font-weight:700;display:inline-flex;align-items:center;gap:5px;letter-spacing:.2px}
.chip-turbina{background:rgba(15,163,177,.15);color:var(--turbina-clara);border:1px solid rgba(15,163,177,.35)}
.chip-luz{background:rgba(244,163,64,.15);color:var(--luz);border:1px solid rgba(244,163,64,.35)}
.chip-sucesso{background:rgba(63,191,143,.15);color:var(--sucesso);border:1px solid rgba(63,191,143,.35)}
.chip-alerta{background:rgba(226,87,76,.15);color:var(--alerta);border:1px solid rgba(226,87,76,.35)}

/* ── BUTTONS ── */
.btn{width:100%;border:none;border-radius:14px;padding:16px;font-size:14.5px;font-weight:700;cursor:pointer;letter-spacing:.1px;transition:transform .12s,filter .2s;font-family:var(--sans)}
.btn:active{transform:scale(.97)}
.btn-luz{background:linear-gradient(135deg,var(--luz),var(--luz-clara));color:#1A1003;box-shadow:0 12px 26px -12px rgba(244,163,64,.5)}
.btn-turbina{background:linear-gradient(135deg,var(--turbina),var(--turbina-clara));color:#06141B;box-shadow:0 12px 26px -12px rgba(15,163,177,.5)}
.btn-outline{background:transparent;border:1.5px solid var(--linha);color:var(--texto)}
.btn-alerta{background:linear-gradient(135deg,var(--alerta),#F2867D);color:#1A0604}
.btn:disabled{opacity:.35;cursor:not-allowed;filter:grayscale(.3)}
.btn-sm{padding:11px;font-size:13px;border-radius:11px}

/* ── FORM ── */
.field-label{font-size:10.5px;color:var(--discreto);font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin-bottom:7px;display:block}
.select-wrap{position:relative;margin-bottom:14px}
select{width:100%;background:var(--rio-painel);border:1.5px solid var(--linha);border-radius:12px;padding:13px 14px;color:var(--texto);font-size:14px;appearance:none;outline:none;font-family:var(--sans);transition:border .2s}
select:focus{border-color:var(--luz)}
select option{background:var(--rio-painel)}
.select-icon{position:absolute;right:14px;top:50%;transform:translateY(-50%);color:var(--discreto);pointer-events:none;font-size:10px}

.seg{display:flex;background:var(--rio-painel);border-radius:12px;padding:4px;gap:4px;margin-bottom:16px;border:1px solid var(--linha)}
.seg-btn{flex:1;padding:11px;background:transparent;color:var(--discreto);border:none;border-radius:9px;font-weight:700;font-size:12.5px;cursor:pointer;transition:all .2s;font-family:var(--sans)}
.seg-btn.active{background:var(--luz);color:#1A1003}

.price-card{border-radius:16px;padding:18px;background:linear-gradient(165deg,rgba(244,163,64,.08),var(--rio-painel));border:1px solid rgba(244,163,64,.3);margin-bottom:14px}
.price-row{display:flex;justify-content:space-between;align-items:flex-end}
.price-num{font-family:var(--serif);font-size:30px;font-weight:700;color:var(--luz)}
.price-label{font-size:10px;color:var(--discreto);text-transform:uppercase;letter-spacing:.5px;font-weight:700}

/* ── CITY CARD ── */
.city-card{border-radius:16px;padding:16px;margin-bottom:10px;cursor:pointer;border:1.5px solid var(--linha);background:var(--rio-card);transition:all .15s;display:flex;justify-content:space-between;align-items:center}
.city-card.sel{border-color:var(--luz);background:linear-gradient(165deg,rgba(244,163,64,.08),var(--rio-card))}
.city-name{font-family:var(--serif);font-size:15px;font-weight:600}
.city-meta{font-size:11px;color:var(--discreto);margin-top:4px}
.city-price{font-family:var(--serif);font-size:20px;font-weight:700;color:var(--luz);text-align:right}

/* ── MAP ── */
.map-wrap{border-radius:18px;overflow:hidden;background:#071920;position:relative;border:1px solid var(--linha)}
#liveMap{width:100%;display:block}
.map-legend{display:flex;gap:16px;padding:13px 15px;flex-wrap:wrap;background:var(--rio-painel)}
.leg-item{display:flex;align-items:center;gap:7px;font-size:10.5px;font-weight:600;color:var(--discreto)}
.leg-dot{width:8px;height:8px;border-radius:50%}

/* ── DRIVER ROW ── */
.driver-row{display:flex;align-items:center;gap:13px;padding:12px 2px;border-bottom:1px solid var(--linha)}
.driver-row:last-child{border-bottom:none}
.driver-avatar{width:42px;height:42px;border-radius:12px;background:var(--rio-painel);display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0;position:relative;border:1px solid var(--linha)}
.driver-avatar::after{content:'';position:absolute;bottom:-2px;right:-2px;width:10px;height:10px;border-radius:50%;background:var(--sucesso);border:2px solid var(--rio-card)}
.driver-name{font-size:13.5px;font-weight:700}
.driver-meta{font-size:10.5px;color:var(--discreto);margin-top:1px}
.driver-eta{margin-left:auto;text-align:right}
.driver-eta-n{font-size:13px;font-weight:700;color:var(--sucesso)}
.driver-eta-l{font-size:9px;color:var(--discreto)}

/* ── CHAT ── */
#chat-screen{display:flex;flex-direction:column;height:calc(100vh - 158px)}
.chat-head{display:flex;align-items:center;gap:11px;margin-bottom:8px;flex-shrink:0;padding-top:2px}
.bot-avatar{width:40px;height:40px;border-radius:11px;background:linear-gradient(160deg,var(--turbina),var(--rio-painel));display:flex;align-items:center;justify-content:center;font-size:18px;border:1px solid rgba(95,208,220,.25)}
.chat-head-name{font-family:var(--serif);font-size:15px;font-weight:600}
.chat-head-sub{font-size:10px;color:var(--discreto)}
#chat-msgs{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:11px;padding:6px 0 8px;min-height:0}
.msg-row{display:flex;align-items:flex-end;gap:8px}
.msg-row.user{flex-direction:row-reverse}
.msg-bubble{border-radius:15px;padding:11px 14px;max-width:79%;font-size:13px;line-height:1.58;white-space:pre-line;border:1px solid var(--linha)}
.msg-bubble.bot{background:var(--rio-painel);border-radius:15px 15px 15px 4px}
.msg-bubble.user{background:var(--luz);color:#1A1003;border-color:transparent;border-radius:15px 15px 4px 15px;font-weight:600}
.msg-av{font-size:17px;flex-shrink:0}
.typing-dots{display:flex;gap:4px;padding:6px 2px}
.tdot{width:5px;height:5px;background:var(--discreto);border-radius:50%;animation:bounce .9s infinite}
.tdot:nth-child(2){animation-delay:.15s}.tdot:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
#chat-sugs{display:flex;gap:7px;overflow-x:auto;padding:9px 0;flex-shrink:0;scrollbar-width:none}
#chat-sugs::-webkit-scrollbar{display:none}
.sug-btn{background:var(--rio-painel);border:1px solid var(--linha);border-radius:18px;padding:7px 13px;font-size:11px;font-weight:600;color:var(--texto);white-space:nowrap;cursor:pointer;flex-shrink:0;font-family:var(--sans)}
#chat-input-row{display:flex;gap:8px;padding:8px 0 4px;flex-shrink:0}
#chat-input{flex:1;background:var(--rio-painel);border:1.5px solid var(--linha);border-radius:12px;padding:12px 15px;color:var(--texto);font-size:14px;outline:none;font-family:var(--sans)}
#chat-input:focus{border-color:var(--turbina)}
#chat-send{background:var(--luz);border:none;border-radius:12px;width:47px;height:47px;font-size:17px;cursor:pointer;flex-shrink:0;color:#1A1003;font-weight:700}

/* ── INCOMING CALL ── */
.incoming-overlay{position:fixed;inset:0;background:rgba(6,20,27,.88);backdrop-filter:blur(7px);z-index:200;display:flex;align-items:center;justify-content:center;padding:24px}
.incoming-overlay.hidden{display:none}
.incoming-card{width:100%;max-width:380px;background:var(--rio-card);border:1.5px solid var(--luz);border-radius:22px;padding:28px 24px;text-align:center;box-shadow:0 0 0 1px rgba(244,163,64,.15),0 40px 70px -25px rgba(244,163,64,.35);animation:popIn .35s cubic-bezier(.16,1,.3,1)}
@keyframes popIn{from{transform:scale(.88);opacity:0}to{transform:scale(1);opacity:1}}
.ring-anim{width:74px;height:74px;border-radius:50%;background:linear-gradient(160deg,var(--luz),var(--turbina));margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:32px;animation:ring 1s infinite}
@keyframes ring{0%,100%{transform:rotate(-7deg)}50%{transform:rotate(7deg)}}
.incoming-title{font-family:var(--serif);font-size:20px;font-weight:700;margin-bottom:5px}
.incoming-sub{font-size:12px;color:var(--discreto);margin-bottom:20px}
.incoming-route{background:var(--rio-painel);border-radius:13px;padding:14px;margin-bottom:20px;text-align:left}
.route-line{display:flex;align-items:center;gap:10px;font-size:12px;padding:5px 0}
.route-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.incoming-fare{font-family:var(--serif);font-size:27px;font-weight:700;color:var(--luz);margin-bottom:20px}
.incoming-actions{display:flex;gap:10px}
.timer-bar{height:4px;background:var(--rio-painel);border-radius:6px;overflow:hidden;margin-bottom:20px}
.timer-fill{height:100%;background:linear-gradient(90deg,var(--luz),var(--alerta));border-radius:6px;animation:timerShrink 12s linear forwards}
@keyframes timerShrink{from{width:100%}to{width:0%}}

/* ── DRIVER TOGGLE ── */
.driver-toggle-card{border-radius:20px;padding:24px;text-align:center;margin-bottom:16px;border:1px solid var(--linha);transition:background .3s}
.driver-toggle-card.off{background:var(--rio-card)}
.driver-toggle-card.on{background:linear-gradient(165deg,rgba(63,191,143,.12),var(--rio-card))}
.toggle-switch{width:60px;height:32px;border-radius:18px;background:var(--rio-painel);border:1px solid var(--linha);margin:16px auto 0;position:relative;cursor:pointer;transition:background .25s}
.toggle-switch.on{background:linear-gradient(135deg,var(--sucesso),var(--turbina))}
.toggle-knob{width:24px;height:24px;border-radius:50%;background:#fff;position:absolute;top:3px;left:3px;transition:left .25s;box-shadow:0 2px 6px rgba(0,0,0,.3)}
.toggle-switch.on .toggle-knob{left:33px}

.progress-track{height:7px;background:var(--rio-painel);border-radius:8px;overflow:hidden;margin:11px 0}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--turbina),var(--luz));border-radius:8px;transition:width .3s ease}

.stars-row{display:flex;gap:9px;font-size:28px;justify-content:center;margin:15px 0;cursor:pointer}
.star{transition:transform .2s;opacity:.25}
.star.active{opacity:1;transform:scale(1.15)}

.sos-card{border:1.5px solid rgba(226,87,76,.3);background:rgba(226,87,76,.05);border-radius:16px;padding:15px 17px;margin-bottom:14px}

/* ── SPLASH ── */
#splash{position:fixed;inset:0;z-index:999;background:var(--rio-fundo);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .5s}
#splash.hide{opacity:0;pointer-events:none}
.splash-mark{width:88px;height:88px;border-radius:22px;background:linear-gradient(160deg,var(--turbina) 0%,var(--rio-painel) 100%);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;border:1px solid rgba(95,208,220,.3);box-shadow:0 25px 60px -15px rgba(15,163,177,.4)}
.splash-mark::after{content:'';position:absolute;inset:0;background:linear-gradient(115deg,transparent 30%,rgba(244,163,64,.6) 50%,transparent 70%);transform:translateX(-100%);animation:sheen 2.2s ease-in-out infinite}
.splash-mark svg{width:42px;height:42px;position:relative;z-index:1}
.splash-name{font-family:var(--serif);font-size:32px;font-weight:700;letter-spacing:-.5px}
.splash-name em{font-style:italic;color:var(--luz)}
.splash-sub{color:var(--discreto);font-size:12.5px;letter-spacing:.8px;text-transform:uppercase}
.splash-bar{width:150px;height:3px;background:var(--rio-painel);border-radius:4px;overflow:hidden;margin-top:8px}
.splash-fill{height:100%;background:linear-gradient(90deg,var(--turbina),var(--luz));border-radius:4px;animation:load 2s ease forwards}
@keyframes load{from{width:0}to{width:100%}}

.info-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--linha)}
.info-row:last-child{border-bottom:none}
.info-label{font-size:12px;color:var(--discreto)}
.info-val{font-size:12px;font-weight:700}
</style>
</head>
<body>

<div id="splash">
  <div class="splash-mark">
    <svg viewBox="0 0 48 48" fill="none"><path d="M6 30c4-9 9-15 18-15s14 6 18 15" stroke="#F4A340" stroke-width="3" stroke-linecap="round"/><path d="M6 36c4-9 9-15 18-15s14 6 18 15" stroke="#EAF2F3" stroke-width="2.4" stroke-linecap="round" opacity=".55"/></svg>
  </div>
  <div class="splash-name serif">Move<em>PA</em></div>
  <div class="splash-sub">Paulo Afonso · Bahia</div>
  <div class="splash-bar"><div class="splash-fill"></div></div>
</div>

<div id="app">
  <svg id="riverlines" viewBox="0 0 430 932" preserveAspectRatio="none">
    <path d="M-20 120 C 100 160, 180 80, 300 140 S 480 180, 560 120" stroke="#0FA3B1" stroke-width="1" fill="none" opacity=".18"/>
    <path d="M-20 600 C 90 560, 200 660, 320 600 S 480 540, 560 610" stroke="#F4A340" stroke-width="1" fill="none" opacity=".12"/>
  </svg>

  <div id="header">
    <button class="back-btn" id="backBtn" onclick="goHome()">‹</button>
    <div class="brandmark">
      <svg viewBox="0 0 48 48" fill="none"><path d="M6 30c4-9 9-15 18-15s14 6 18 15" stroke="#F4A340" stroke-width="3.4" stroke-linecap="round"/><path d="M6 36c4-9 9-15 18-15s14 6 18 15" stroke="#EAF2F3" stroke-width="2.6" stroke-linecap="round" opacity=".6"/></svg>
    </div>
    <div class="title-block">
      <div class="title-main serif" id="headerTitle">MovePA</div>
      <div class="title-sub">Paulo Afonso · BA</div>
    </div>
    <div class="status-pill"><span class="pulse"></span>Em operação</div>
  </div>

  <div id="body">

    <div class="tela ativa" id="t-home">

      <div class="hero">
        <div class="hero-rule"></div>
        <div class="hero-eyebrow">⚡ 14 motoristas em rota agora</div>
        <div class="hero-h1 serif">A cidade<br>em <em>movimento</em></div>
        <div class="hero-sub">Corridas dentro de Paulo Afonso e viagens para a região — com a confiança de quem te leva todos os dias.</div>
        <div class="hero-meter">
          <div class="meter-item"><div class="meter-n serif">2<span>min</span></div><div class="meter-l">Tempo médio</div></div>
          <div class="meter-item"><div class="meter-n serif">4.9</div><div class="meter-l">Avaliação</div></div>
          <div class="meter-item"><div class="meter-n serif">R$8</div><div class="meter-l">Corrida mínima</div></div>
        </div>
      </div>

      <div class="action-grid">
        <button class="action-card ac-urbana" onclick="abrir('t-pedir','Pedir corrida')">
          <span class="action-num serif">01</span>
          <div class="action-label">Pedir corrida</div>
          <div class="action-sub">Dentro de Paulo Afonso</div>
        </button>
        <button class="action-card ac-inter" onclick="abrir('t-inter','Intermunicipal')">
          <span class="action-num serif">02</span>
          <div class="action-label">Viajar</div>
          <div class="action-sub">Outras cidades da região</div>
        </button>
        <button class="action-card ac-gps" onclick="abrir('t-mapa','Rastreio ao vivo')">
          <span class="action-num serif">03</span>
          <div class="action-label">Acompanhar</div>
          <div class="action-sub">Rastreio em tempo real</div>
        </button>
        <button class="action-card ac-chat" onclick="abrir('t-chat','Central de Ajuda')">
          <span class="action-num serif">04</span>
          <div class="action-label">Central de ajuda</div>
          <div class="action-sub">Suporte 24 horas</div>
        </button>
      </div>

      <div class="sec-head">
        <div class="sec-title serif">Destinos frequentes</div>
        <div class="sec-link" onclick="abrir('t-pedir','Pedir corrida')">ver todos</div>
      </div>
      <div class="card">
        <div class="dest-item" onclick="setDestinoRapido('Terminal Rodoviário')">
          <div class="dest-mark"></div>
          <div><div class="dest-name">Terminal Rodoviário</div><div class="dest-time">cerca de 8 min</div></div>
          <div class="dest-arrow">→</div>
        </div>
        <div class="dest-item" onclick="setDestinoRapido('Hospital Regional')">
          <div class="dest-mark"></div>
          <div><div class="dest-name">Hospital Regional</div><div class="dest-time">cerca de 6 min</div></div>
          <div class="dest-arrow">→</div>
        </div>
        <div class="dest-item" onclick="setDestinoRapido('CHESF')">
          <div class="dest-mark"></div>
          <div><div class="dest-name">CHESF</div><div class="dest-time">cerca de 10 min</div></div>
          <div class="dest-arrow">→</div>
        </div>
        <div class="dest-item" onclick="setDestinoRapido('UNEB')">
          <div class="dest-mark"></div>
          <div><div class="dest-name">UNEB</div><div class="dest-time">cerca de 7 min</div></div>
          <div class="dest-arrow">→</div>
        </div>
      </div>

      <div class="sec-head"><div class="sec-title serif">Motorista parceiro</div></div>
      <div class="card driver-promo">
        <div class="driver-promo-label serif">Receba chamados na hora</div>
        <div class="driver-promo-text">Ative o modo motorista e comece a atender passageiros de Paulo Afonso agora mesmo, sem mensalidade.</div>
        <button class="btn btn-luz" onclick="abrir('t-driver','Modo Motorista')">Entrar no modo motorista</button>
      </div>

    </div>

    <div class="tela" id="t-pedir">
      <div class="seg">
        <button class="seg-btn active" id="seg-urbana" onclick="setSeg('urbana')">Carro</button>
        <button class="seg-btn" id="seg-mototaxi" onclick="setSeg('moto')">Mototáxi</button>
      </div>

      <div class="card">
        <label class="field-label">Saindo de</label>
        <div class="select-wrap">
          <select id="selOrigem" onchange="calcularPreco()">
            <option value="">Escolher origem...</option>
            <option>Minha localização atual</option>
            <option>Terminal Rodoviário</option><option>Hospital Regional</option><option>CHESF</option>
            <option>UNEB</option><option>Aeroporto de Paulo Afonso</option><option>Shopping Alternativo PA</option>
            <option>Bairro Cohab</option><option>Centro</option><option>Mercado Municipal</option>
          </select><span class="select-icon">▾</span>
        </div>
        <label class="field-label">Indo para</label>
        <div class="select-wrap" style="margin-bottom:6px">
          <select id="selDestino" onchange="calcularPreco()">
            <option value="">Escolher destino...</option>
            <option>Terminal Rodoviário</option><option>Hospital Regional</option><option>CHESF</option><option>UNEB</option>
            <option>Aeroporto de Paulo Afonso</option><option>Shopping Alternativo PA</option><option>Bairro Cohab</option>
            <option>Centro</option><option>Mercado Municipal</option>
          </select><span class="select-icon">▾</span>
        </div>
      </div>

      <div class="card">
        <label class="field-label">Pagamento</label>
        <div class="select-wrap" style="margin-bottom:0">
          <select id="selPag"><option>Dinheiro</option><option>Pix</option><option>Cartão de crédito</option><option>Cartão de débito</option></select>
          <span class="select-icon">▾</span>
        </div>
      </div>

      <div class="price-card" id="priceBox" style="display:none">
        <div class="price-row">
          <div><div class="price-label">Valor estimado</div><div class="price-num serif" id="precoVal">R$ —</div></div>
          <div style="text-align:right"><div class="price-label">Chegada</div><div style="font-size:16px;font-weight:700" id="tempoVal">— min</div></div>
        </div>
        <div style="margin-top:13px"><span class="chip chip-turbina">3 motoristas nas proximidades</span></div>
      </div>

      <button class="btn btn-luz" id="btnPedir" onclick="pedirCorrida('urbana')" disabled>Escolha origem e destino</button>

      <div class="card" style="margin-top:14px">
        <div class="info-row"><span class="info-label">Tarifa base</span><span class="info-val">R$ 4,00</span></div>
        <div class="info-row"><span class="info-label">Por quilômetro</span><span class="info-val">R$ 2,50</span></div>
        <div class="info-row"><span class="info-label">Período noturno (22h–6h)</span><span class="info-val">+20%</span></div>
        <div class="info-row"><span class="info-label">Cancelamento sem custo até</span><span class="info-val">3 min</span></div>
      </div>
    </div>

    <div class="tela" id="t-inter">
      <div class="card" style="background:linear-gradient(165deg,rgba(15,163,177,.10),var(--rio-card));border-color:rgba(15,163,177,.3)">
        <div style="font-size:10.5px;color:var(--discreto);text-transform:uppercase;letter-spacing:.6px;font-weight:700;margin-bottom:6px">Partindo de</div>
        <div style="font-size:18px;font-weight:600" class="serif">Paulo Afonso, Bahia</div>
        <div style="font-size:11.5px;color:var(--discreto);margin-top:6px">Horário de saída combinado direto com o motorista</div>
      </div>

      <div class="sec-head"><div class="sec-title serif">Escolha o destino</div></div>

      <div class="city-card" onclick="selecionarCidade(this,'Aracaju – SE',280,'3h20',185)"><div><div class="city-name">Aracaju, SE</div><div class="city-meta">280 km · 3h20</div></div><div class="city-price serif">R$185</div></div>
      <div class="city-card" onclick="selecionarCidade(this,'Maceió – AL',230,'2h50',158)"><div><div class="city-name">Maceió, AL</div><div class="city-meta">230 km · 2h50</div></div><div class="city-price serif">R$158</div></div>
      <div class="city-card" onclick="selecionarCidade(this,'Salvador – BA',500,'6h',295)"><div><div class="city-name">Salvador, BA</div><div class="city-meta">500 km · 6h</div></div><div class="city-price serif">R$295</div></div>
      <div class="city-card" onclick="selecionarCidade(this,'Petrolina – PE',210,'2h30',140)"><div><div class="city-name">Petrolina, PE</div><div class="city-meta">210 km · 2h30</div></div><div class="city-price serif">R$140</div></div>
      <div class="city-card" onclick="selecionarCidade(this,'Juazeiro – BA',195,'2h20',132)"><div><div class="city-name">Juazeiro, BA</div><div class="city-meta">195 km · 2h20</div></div><div class="city-price serif">R$132</div></div>
      <div class="city-card" onclick="selecionarCidade(this,'Delmiro Gouveia – AL',65,'50min',72)"><div><div class="city-name">Delmiro Gouveia, AL</div><div class="city-meta">65 km · 50min</div></div><div class="city-price serif">R$72</div></div>
      <div class="city-card" onclick="selecionarCidade(this,'Glória – BA',70,'55min',75)"><div><div class="city-name">Glória, BA</div><div class="city-meta">70 km · 55min</div></div><div class="city-price serif">R$75</div></div>

      <button class="btn btn-turbina" id="btnInter" onclick="pedirCorrida('inter')" disabled style="margin-top:6px">Escolha um destino</button>
    </div>

    <div class="tela" id="t-mapa">
      <div class="sec-head"><div class="sec-title serif">Rastreio ao vivo</div></div>

      <div id="googleMapReal" style="display:none;width:100%;height:260px;border-radius:18px;border:1px solid var(--linha);margin-bottom:14px;overflow:hidden"></div>

      <div class="map-wrap" id="mapaIlustrativo">
        <svg id="liveMap" viewBox="0 0 200 150">
          <rect width="200" height="150" fill="#071920"/>
          <g stroke="#1B3A4B" stroke-width="1.1" fill="none">
            <line x1="0" y1="75" x2="200" y2="75"/><line x1="100" y1="0" x2="100" y2="150"/>
            <line x1="40" y1="0" x2="40" y2="150"/><line x1="160" y1="0" x2="160" y2="150"/>
            <line x1="0" y1="35" x2="200" y2="35"/><line x1="0" y1="115" x2="200" y2="115"/>
            <line x1="15" y1="0" x2="90" y2="150" stroke-width=".5" opacity=".5"/>
            <line x1="130" y1="0" x2="190" y2="150" stroke-width=".5" opacity=".5"/>
          </g>
          <g font-size="4" font-family="Archivo, sans-serif" fill="#2C5366">
            <text x="42" y="73">Av. Paulo Afonso</text><text x="103" y="33">R. das Flores</text>
          </g>
          <circle cx="100" cy="75" r="5.2" fill="#F4A340" opacity=".95"/>
          <text x="106" y="78" font-size="4.6" fill="#F4A340" font-weight="bold" font-family="Archivo">Centro</text>
          <circle cx="40" cy="35" r="4" fill="#0FA3B1" opacity=".9"/>
          <text x="45" y="37" font-size="4" fill="#5FD0DC" font-family="Archivo">CHESF</text>
          <circle cx="155" cy="28" r="4" fill="#3FBF8F" opacity=".9"/>
          <text x="160" y="30" font-size="4" fill="#3FBF8F" font-family="Archivo">Hospital</text>
          <circle cx="168" cy="105" r="4" fill="#5FD0DC" opacity=".9"/>
          <text x="148" y="116" font-size="4" fill="#5FD0DC" font-family="Archivo">Rodoviária</text>
          <circle cx="35" cy="108" r="4" fill="#F4A340" opacity=".9"/>
          <text x="40" y="111" font-size="4" fill="#F4A340" font-family="Archivo">UNEB</text>
          <circle cx="100" cy="75" r="9" fill="none" stroke="#F4A340" stroke-width="1" opacity=".3">
            <animate attributeName="r" values="9;17;9" dur="2.2s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values=".3;0;.3" dur="2.2s" repeatCount="indefinite"/>
          </circle>
          <circle cx="100" cy="75" r="5.2" fill="#F4A340"/>
          <text x="105" y="86" font-size="4.4" fill="#F4A340" font-weight="bold" font-family="Archivo">Você</text>
          <g id="liveDriver"><circle r="5.2" fill="#0FA3B1"/><text text-anchor="middle" dy="2.3" font-size="6.5">🚗</text></g>
          <g id="liveDriver2"><circle r="4.8" fill="#3FBF8F"/><text text-anchor="middle" dy="2" font-size="6">🏍️</text></g>
          <text x="4" y="146" font-size="3.6" fill="#1B3A4B">Paulo Afonso – BA · MovePA</text>
        </svg>
        <div class="map-legend">
          <div class="leg-item"><span class="leg-dot" style="background:var(--luz)"></span>Você</div>
          <div class="leg-item"><span class="leg-dot" style="background:var(--turbina)"></span>Carro</div>
          <div class="leg-item"><span class="leg-dot" style="background:var(--sucesso)"></span>Moto</div>
        </div>
      </div>

      <div class="sec-head" style="margin-top:14px"><div class="sec-title serif">Motoristas nas proximidades</div></div>
      <div class="card">
        <div class="driver-row"><div class="driver-avatar">👤</div><div><div class="driver-name" id="mapMotName1">Carlos Silva</div><div class="driver-meta">Ônix Prata · ⭐ 4.9</div></div><div class="driver-eta"><div class="driver-eta-n">3 min</div><div class="driver-eta-l">1.2 km</div></div></div>
        <div class="driver-row"><div class="driver-avatar">👤</div><div><div class="driver-name">Ana Lima</div><div class="driver-meta">HB20 Branco · ⭐ 4.8</div></div><div class="driver-eta"><div class="driver-eta-n">5 min</div><div class="driver-eta-l">2.1 km</div></div></div>
        <div class="driver-row"><div class="driver-avatar">🏍️</div><div><div class="driver-name">Junior (Moto)</div><div class="driver-meta">CG 160 · ⭐ 4.7</div></div><div class="driver-eta"><div class="driver-eta-n">2 min</div><div class="driver-eta-l">0.8 km</div></div></div>
      </div>

      <button class="btn btn-luz" onclick="abrir('t-pedir','Pedir corrida')">Pedir corrida agora</button>
    </div>

    <div class="tela" id="t-chat">
      <div id="chat-screen">
        <div class="chat-head">
          <div class="bot-avatar">◐</div>
          <div><div class="chat-head-name serif">Central de Ajuda</div><div class="chat-head-sub">responde em segundos · 24h</div></div>
          <span class="chip chip-sucesso" style="margin-left:auto">online</span>
        </div>
        <div id="chat-msgs">
          <div class="msg-row"><div class="msg-av">◐</div><div class="msg-bubble bot">Olá! Posso te ajudar com corridas, preços, segurança e muito mais. O que você precisa saber?</div></div>
        </div>
        <div id="chat-sugs">
          <button class="sug-btn" onclick="enviarSugestao('Quais os preços?')">Preços</button>
          <button class="sug-btn" onclick="enviarSugestao('É seguro?')">Segurança</button>
          <button class="sug-btn" onclick="enviarSugestao('Como cancelar?')">Cancelar</button>
          <button class="sug-btn" onclick="enviarSugestao('Quero ser motorista')">Ser motorista</button>
          <button class="sug-btn" onclick="enviarSugestao('Cidades atendidas')">Cidades</button>
        </div>
        <div id="chat-input-row">
          <input type="text" id="chatInput" placeholder="Digite sua mensagem..." onkeydown="if(event.key==='Enter')enviarMsg()"/>
          <button id="chat-send" onclick="enviarMsg()">→</button>
        </div>
      </div>
    </div>

    <div class="tela" id="t-corrida">
      <div class="card" style="text-align:center;padding:32px 18px">
        <div style="font-size:46px;margin-bottom:10px" id="statusIcon">○</div>
        <div class="serif" style="font-size:19px;font-weight:600" id="statusLabel">Chamando motoristas</div>
        <div style="font-size:12px;color:var(--discreto);margin-top:7px" id="statusSub">Avisamos os motoristas mais próximos de você</div>
      </div>

      <div class="card" id="cardBuscando">
        <div class="progress-track"><div class="progress-fill" id="buscandoBar" style="width:0%"></div></div>
        <div style="text-align:center;font-size:11.5px;color:var(--discreto)">Enviando chamado para motoristas próximos</div>
      </div>

      <div class="card" id="cardMotorista" style="display:none">
        <div style="display:flex;align-items:center;gap:14px">
          <div class="driver-avatar" style="width:50px;height:50px;font-size:22px">👤</div>
          <div style="flex:1">
            <div style="font-size:16px;font-weight:700" id="motNome">Carlos Silva</div>
            <div style="font-size:12px;color:var(--discreto)" id="motCarro">Ônix Prata · ABC-1234</div>
            <div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap">
              <span class="chip chip-luz">⭐ 4.9</span>
              <span class="chip chip-turbina" id="motEta">chegando em 3 min</span>
            </div>
          </div>
        </div>
        <div style="display:flex;gap:8px;margin-top:15px">
          <button class="btn btn-luz btn-sm" style="flex:1" onclick="embarcar()">Motorista chegou</button>
          <button class="btn btn-alerta btn-sm" style="flex:1" onclick="cancelarCorrida()">Cancelar</button>
        </div>
        <div style="display:flex;gap:8px;margin-top:9px">
          <a id="linkLigar" href="tel:" style="flex:1;text-decoration:none"><button class="btn btn-outline btn-sm" style="width:100%">Ligar</button></a>
          <a id="linkWhats" href="https://wa.me/" target="_blank" style="flex:1;text-decoration:none"><button class="btn btn-outline btn-sm" style="width:100%">WhatsApp</button></a>
        </div>
        <div style="text-align:center;font-size:10.5px;color:var(--discreto);margin-top:9px" id="motTelExibido"></div>
      </div>

      <div class="card" id="cardViagem" style="display:none">
        <div class="sec-title serif" style="margin-bottom:9px">A caminho do destino</div>
        <div class="progress-track"><div class="progress-fill" id="viagemBar" style="width:0%"></div></div>
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--discreto);margin-bottom:13px">
          <span>Origem</span><span style="color:var(--luz);font-weight:700" id="viagemPct">0%</span><span>Destino</span>
        </div>
        <svg viewBox="0 0 200 70" style="width:100%;border-radius:12px;background:#071920;margin-bottom:13px">
          <line x1="10" y1="35" x2="190" y2="35" stroke="#1B3A4B" stroke-width="2"/>
          <circle cx="10" cy="35" r="5" fill="#3FBF8F"/><circle cx="190" cy="35" r="5" fill="#E2574C"/>
          <circle id="carroSvg" cx="10" cy="35" r="6" fill="#0FA3B1"/><text id="carroEmoji" x="6" y="38" font-size="8">🚗</text>
        </svg>
        <button class="btn btn-outline btn-sm" onclick="compartilharRota()">Compartilhar rota com a família</button>
      </div>

      <div class="card" id="cardChegou" style="display:none;text-align:center">
        <div style="font-size:42px;margin-bottom:9px">◉</div>
        <div class="serif" style="font-size:18px;font-weight:600;color:var(--luz)">Chegou ao destino</div>
        <div style="font-size:12px;color:var(--discreto);margin:7px 0 4px">Como foi a viagem com Carlos?</div>
        <div class="stars-row" id="starsRow">
          <span class="star" onclick="avaliar(1)">★</span><span class="star" onclick="avaliar(2)">★</span><span class="star" onclick="avaliar(3)">★</span><span class="star" onclick="avaliar(4)">★</span><span class="star" onclick="avaliar(5)">★</span>
        </div>
        <button class="btn btn-luz" onclick="goHome()" style="margin-top:7px">Voltar ao início</button>
      </div>

      <div class="sos-card">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="font-size:22px">▲</span>
          <div style="flex:1"><div style="font-size:12.5px;font-weight:700;color:var(--alerta)">Emergência</div><div style="font-size:10.5px;color:var(--discreto)">SAMU · Polícia · contato de confiança</div></div>
          <button class="btn btn-alerta btn-sm" style="width:auto;padding:10px 18px" onclick="acionarSOS()">SOS</button>
        </div>
      </div>
    </div>

    <div class="tela" id="t-driver">
      <div class="driver-toggle-card off" id="driverToggleCard">
        <div style="font-size:26px" id="driverModeIcon">○</div>
        <div class="serif" style="font-size:18px;font-weight:600;margin-top:8px" id="driverModeLabel">Você está offline</div>
        <div style="font-size:12px;color:var(--discreto);margin-top:4px" id="driverModeSub">Ative para começar a receber chamados</div>
        <div class="toggle-switch" id="driverSwitch" onclick="toggleDriverMode()"><div class="toggle-knob"></div></div>
      </div>

      <div class="card" style="text-align:center">
        <div style="display:flex;justify-content:space-around">
          <div><div class="serif" style="font-size:20px;font-weight:700;color:var(--luz)">R$127</div><div style="font-size:10px;color:var(--discreto)">hoje</div></div>
          <div><div class="serif" style="font-size:20px;font-weight:700">8</div><div style="font-size:10px;color:var(--discreto)">corridas</div></div>
          <div><div class="serif" style="font-size:20px;font-weight:700;color:var(--turbina-clara)">4.9</div><div style="font-size:10px;color:var(--discreto)">avaliação</div></div>
        </div>
      </div>

      <div class="card" style="background:linear-gradient(165deg,rgba(244,163,64,.08),var(--rio-card));border-color:rgba(244,163,64,.3)">
        <div style="font-size:13px;font-weight:700;margin-bottom:7px" class="serif">Simular chamado de teste</div>
        <div style="font-size:11.5px;color:var(--discreto);margin-bottom:13px;line-height:1.6">Ative o modo online e simule receber um chamado de corrida, como se fosse real.</div>
        <button class="btn btn-outline btn-sm" onclick="simularChamado()" id="btnSimular" disabled>Simular chamado agora</button>
      </div>

      <div class="sec-head"><div class="sec-title serif">Últimas corridas</div></div>
      <div class="card">
        <div class="info-row"><span class="info-label">Centro → Rodoviária</span><span class="info-val" style="color:var(--luz)">+R$14</span></div>
        <div class="info-row"><span class="info-label">UNEB → Cohab</span><span class="info-val" style="color:var(--luz)">+R$11</span></div>
        <div class="info-row"><span class="info-label">CHESF → Centro</span><span class="info-val" style="color:var(--luz)">+R$16</span></div>
      </div>
    </div>

  </div>

  <nav id="nav">
    <button class="nav-btn active" onclick="abrir('t-home','MovePA');setNav(this)"><span class="ni">⌂</span>Início<span class="nav-rule"></span></button>
    <button class="nav-btn" onclick="abrir('t-pedir','Pedir corrida');setNav(this)"><span class="ni">◷</span>Corrida<span class="nav-rule"></span></button>
    <button class="nav-btn" onclick="abrir('t-inter','Intermunicipal');setNav(this)"><span class="ni">↗</span>Viajar<span class="nav-rule"></span></button>
    <button class="nav-btn" onclick="abrir('t-mapa','Rastreio ao vivo');setNav(this)"><span class="ni">◎</span>Rastreio<span class="nav-rule"></span></button>
    <button class="nav-btn" onclick="abrir('t-chat','Central de Ajuda');setNav(this)"><span class="ni">◐</span>Ajuda<span class="nav-rule"></span></button>
  </nav>

  <div class="incoming-overlay hidden" id="incomingOverlay">
    <div class="incoming-card">
      <div class="timer-bar"><div class="timer-fill" id="timerFill"></div></div>
      <div class="ring-anim">◷</div>
      <div class="incoming-title serif">Novo chamado</div>
      <div class="incoming-sub">Maria P. está te chamando</div>
      <div class="incoming-route">
        <div class="route-line"><span class="route-dot" style="background:var(--luz)"></span>Centro, Paulo Afonso</div>
        <div class="route-line"><span class="route-dot" style="background:var(--alerta)"></span>Terminal Rodoviário</div>
      </div>
      <div class="incoming-fare serif">R$ 14,00</div>
      <div class="incoming-actions">
        <button class="btn btn-alerta btn-sm" style="flex:1" onclick="recusarChamado()">Recusar</button>
        <button class="btn btn-luz btn-sm" style="flex:1" onclick="aceitarChamado()">Aceitar</button>
      </div>
    </div>
  </div>

</div>

<script>
/* ════════════════════════════════════════════════════════════════
   PERSONALIZAR PARA CADA MOTORISTA — troque só estes 4 valores
   ════════════════════════════════════════════════════════════════ */
const NOME_MOTORISTA = "Carlos Silva";
const TELEFONE_MOTORISTA = "75991771095"; // só números, com DDD
const CARRO_MOTORISTA = "Ônix Prata";
const PLACA_MOTORISTA = "ABC-1234";
/* ════════════════════════════════════════════════════════════════ */

let telaAtual='t-home', cidadeSel=null, etapa=0, progViagem=0, ivBusca=null, ivViagem=null, driverOnline=false, timerCall=null;

function aplicarDadosMotorista(){
  document.getElementById('motNome').textContent = NOME_MOTORISTA;
  document.getElementById('motCarro').textContent = CARRO_MOTORISTA + ' · ' + PLACA_MOTORISTA;
  document.getElementById('mapMotName1').textContent = NOME_MOTORISTA;
  document.getElementById('linkLigar').href = 'tel:' + TELEFONE_MOTORISTA;
  document.getElementById('linkWhats').href = 'https://wa.me/55' + TELEFONE_MOTORISTA;
  const tel = TELEFONE_MOTORISTA;
  const telFormatado = '(' + tel.slice(0,2) + ') ' + tel.slice(2,7) + '-' + tel.slice(7);
  document.getElementById('motTelExibido').textContent = telFormatado;
}

function abrir(id,titulo){
  document.querySelectorAll('.tela').forEach(t=>{t.classList.remove('ativa');t.style.display='none'});
  const t=document.getElementById(id);
  t.style.display='block'; t.classList.add('ativa'); telaAtual=id;
  document.getElementById('headerTitle').textContent=titulo||'MovePA';
  document.getElementById('backBtn').style.display = id==='t-home'?'none':'flex';
  document.getElementById('body').scrollTop=0;
  if(id==='t-chat') setTimeout(()=>{const m=document.getElementById('chat-msgs');m.scrollTop=m.scrollHeight},80);
  if(id==='t-mapa'){ animarMapa(); carregarGoogleMapsSeConfigurado(); }
}
function goHome(){abrir('t-home','MovePA');setNavById('t-home')}
function setNav(btn){document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active')}
function setNavById(id){const map={'t-home':0,'t-pedir':1,'t-inter':2,'t-mapa':3,'t-chat':4};const btns=document.querySelectorAll('.nav-btn');btns.forEach(b=>b.classList.remove('active'));if(map[id]!==undefined)btns[map[id]].classList.add('active')}

function setDestinoRapido(dest){
  abrir('t-pedir','Pedir corrida'); setNavById('t-pedir');
  setTimeout(()=>{
    document.getElementById('selOrigem').value='Minha localização atual';
    const sel=document.getElementById('selDestino');
    for(let o of sel.options){if(o.value===dest){sel.value=dest;break}}
    calcularPreco();
  },100);
}
function setSeg(tipo){
  document.getElementById('seg-urbana').classList.toggle('active',tipo==='urbana');
  document.getElementById('seg-mototaxi').classList.toggle('active',tipo==='moto');
}
function calcularPreco(){
  const o=document.getElementById('selOrigem').value, d=document.getElementById('selDestino').value;
  const btn=document.getElementById('btnPedir'), box=document.getElementById('priceBox');
  if(o && d && o!==d){
    const preco=Math.floor(Math.random()*17+8);
    const tempo=Math.floor(preco/2.3+3);
    document.getElementById('precoVal').textContent='R$ '+preco+',00';
    document.getElementById('tempoVal').textContent='~'+tempo+' min';
    box.style.display='block'; btn.disabled=false; btn.textContent='Chamar motorista — R$ '+preco;
  } else { box.style.display='none'; btn.disabled=true; btn.textContent='Escolha origem e destino'; }
}
function selecionarCidade(el,nome,dist,tempo,preco){
  document.querySelectorAll('.city-card').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel'); cidadeSel={nome,dist,tempo,preco};
  const btn=document.getElementById('btnInter');
  btn.disabled=false; btn.textContent='Chamar para '+nome+' — R$'+preco;
}
function pedirCorrida(tipo){
  abrir('t-corrida', tipo==='inter'?'Viagem intermunicipal':'Sua corrida'); setNavById('t-corrida');
  etapa=1; resetCorrida();
  document.getElementById('cardBuscando').style.display='block';
  let p=0;
  ivBusca=setInterval(()=>{
    p+=4; document.getElementById('buscandoBar').style.width=Math.min(p,95)+'%';
    if(p>=100){clearInterval(ivBusca); motoristaAchado();}
  },90);
}
function resetCorrida(){
  document.getElementById('cardMotorista').style.display='none';
  document.getElementById('cardViagem').style.display='none';
  document.getElementById('cardChegou').style.display='none';
  document.getElementById('statusIcon').textContent='○';
  document.getElementById('statusLabel').textContent='Chamando motoristas';
  document.getElementById('statusSub').textContent='Avisamos os motoristas mais próximos de você';
}
function motoristaAchado(){
  etapa=2;
  document.getElementById('cardBuscando').style.display='none';
  document.getElementById('statusIcon').textContent='✓';
  document.getElementById('statusLabel').textContent=NOME_MOTORISTA.split(' ')[0]+' aceitou sua corrida';
  document.getElementById('statusSub').textContent='Ele já está vindo até você';
  document.getElementById('cardMotorista').style.display='block';
}
function embarcar(){
  etapa=3;
  document.getElementById('cardMotorista').style.display='none';
  document.getElementById('cardViagem').style.display='block';
  document.getElementById('statusIcon').textContent='◷';
  document.getElementById('statusLabel').textContent='Boa viagem';
  document.getElementById('statusSub').textContent='Acompanhe sua rota em tempo real';
  progViagem=0;
  ivViagem=setInterval(()=>{
    progViagem+=1.6; const p=Math.min(progViagem,100);
    document.getElementById('viagemBar').style.width=p+'%';
    document.getElementById('viagemPct').textContent=Math.floor(p)+'%';
    const x=10+(180*p/100);
    document.getElementById('carroSvg').setAttribute('cx',x);
    document.getElementById('carroEmoji').setAttribute('x',x-3);
    if(p>=100){clearInterval(ivViagem); chegou();}
  },190);
}
function chegou(){
  etapa=4;
  document.getElementById('cardViagem').style.display='none';
  document.getElementById('cardChegou').style.display='block';
  document.getElementById('statusIcon').textContent='◉';
  document.getElementById('statusLabel').textContent='Chegou ao destino';
  document.getElementById('statusSub').textContent='Esperamos que tenha gostado';
}
function cancelarCorrida(){ if(confirm('Cancelar corrida?')){clearInterval(ivBusca);clearInterval(ivViagem);goHome();} }
function avaliar(n){document.querySelectorAll('.star').forEach((s,i)=>s.classList.toggle('active',i<n))}
function acionarSOS(){alert('SOS acionado.\n\nNotificando:\n• SAMU: 192\n• Polícia: 190\n• Seu contato de confiança\n\nFique calmo, ajuda a caminho.')}
function compartilharRota(){
  if(navigator.share){navigator.share({title:'MovePA',text:'Estou em uma corrida pelo MovePA, acompanhe minha rota.',url:location.href})}
  else{alert('Envie este link para alguém de confiança acompanhar sua rota.')}
}
function toggleDriverMode(){
  driverOnline=!driverOnline;
  const sw=document.getElementById('driverSwitch'), card=document.getElementById('driverToggleCard');
  sw.classList.toggle('on',driverOnline); card.classList.toggle('on',driverOnline); card.classList.toggle('off',!driverOnline);
  document.getElementById('driverModeIcon').textContent = driverOnline?'●':'○';
  document.getElementById('driverModeLabel').textContent = driverOnline?'Você está online':'Você está offline';
  document.getElementById('driverModeSub').textContent = driverOnline?'Recebendo chamados perto de você':'Ative para começar a receber chamados';
  document.getElementById('btnSimular').disabled = !driverOnline;
}
function simularChamado(){
  document.getElementById('incomingOverlay').classList.remove('hidden');
  const tf=document.getElementById('timerFill');
  tf.style.animation='none'; void tf.offsetWidth; tf.style.animation='timerShrink 12s linear forwards';
  timerCall=setTimeout(()=>{recusarChamado()},12000);
}
function aceitarChamado(){
  clearTimeout(timerCall);
  document.getElementById('incomingOverlay').classList.add('hidden');
  alert('Chamado aceito.\n\nMaria P. está te esperando no Centro.\nRota traçada até o Terminal Rodoviário.');
}
function recusarChamado(){ clearTimeout(timerCall); document.getElementById('incomingOverlay').classList.add('hidden'); }

const respostas = {
  preco:"Preços no MovePA:\n\nCidade: tarifa base R$4 + R$2,50/km\nIntermunicipal: a partir de R$72 (Delmiro Gouveia)\nPeríodo noturno (22h-6h): +20%\n\nQuer ver uma estimativa? Use 'Pedir corrida'.",
  seguranca:"Segurança é prioridade:\n\nMotoristas verificados (CNH e antecedentes)\nRastreio em tempo real\nCompartilhamento de rota com a família\nBotão SOS em toda corrida\n\nEm caso de qualquer imprevisto, é só chamar.",
  cancelar:"Cancelamento no MovePA:\n\nGratuito até 3 minutos\nApós isso: taxa de R$5\nSe o motorista cancelar, você não paga nada\n\nBasta acessar a tela da corrida e tocar em cancelar.",
  motorista:"Para rodar com a gente:\n\nCNH válida há mais de 2 anos\nCarro 2015 ou mais novo, ou moto regularizada\nAntecedentes limpos\n\nVocê fica com 80-85% de cada corrida, sem mensalidade.\nAtive o 'Modo Motorista' no app para simular como funciona.",
  cidades:"Cidades atendidas pelo MovePA:\n\nPaulo Afonso, BA (base)\nDelmiro Gouveia, AL\nGlória, BA\nJuazeiro, BA\nPetrolina, PE\nMaceió, AL\nAracaju, SE\nSalvador, BA\n\nPara viajar, acesse 'Viajar'.",
  ola:"Olá! Bem-vindo ao MovePA.\n\nPosso ajudar com:\nCorridas em Paulo Afonso\nViagens intermunicipais\nPreços e segurança\nComo virar motorista\n\nFique à vontade para perguntar.",
  default:"Posso ajudar com preços, cidades atendidas, segurança, cancelamento ou como virar motorista. Detalhe sua pergunta ou use um dos botões abaixo."
};
function getResposta(msg){
  const m=msg.toLowerCase();
  if(m.match(/ol[aá]|oi|bom dia|boa tarde|boa noite|e a[ií]/))return respostas.ola;
  if(m.match(/pre[cç]o|valor|quanto|custo|tarifa/))return respostas.preco;
  if(m.match(/seguran[cç]a|seguro|perigo|sos|medo/))return respostas.seguranca;
  if(m.match(/cancelar|cancelamento|desistir/))return respostas.cancelar;
  if(m.match(/motorista|dirigir|trabalhar|ganhar|cadastro/))return respostas.motorista;
  if(m.match(/cidade|intermunicipal|aracaju|salvador|macei[oó]|petrolina|gl[oó]ria|juazeiro/))return respostas.cidades;
  return respostas.default;
}
function addMsg(de,txt){
  const div=document.getElementById('chat-msgs');
  const row=document.createElement('div'); row.className='msg-row'+(de==='user'?' user':'');
  row.innerHTML=(de==='bot'?'<div class="msg-av">◐</div>':'')+'<div class="msg-bubble '+de+'">'+txt.replace(/\n/g,'<br>')+'</div>';
  div.appendChild(row); div.scrollTop=div.scrollHeight;
}
function showTyping(){
  const div=document.getElementById('chat-msgs');
  const row=document.createElement('div'); row.className='msg-row'; row.id='typingRow';
  row.innerHTML='<div class="msg-av">◐</div><div class="msg-bubble bot"><div class="typing-dots"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div></div>';
  div.appendChild(row); div.scrollTop=div.scrollHeight;
}
function enviarMsg(){
  const inp=document.getElementById('chatInput'); const txt=inp.value.trim();
  if(!txt)return; addMsg('user',txt); inp.value=''; showTyping();
  setTimeout(()=>{const t=document.getElementById('typingRow'); if(t)t.remove(); addMsg('bot',getResposta(txt));},850+Math.random()*450);
}
function enviarSugestao(txt){document.getElementById('chatInput').value=txt; enviarMsg();}

let dx=58,dy=40,vx=.55,vy=.4, mx=160,my=110,vmx=-.5,vmy=-.35;
function animarMapa(){
  const d1=document.getElementById('liveDriver'), d2=document.getElementById('liveDriver2');
  function step(){
    dx+=vx; dy+=vy; if(dx>185||dx<10)vx*=-1; if(dy>140||dy<10)vy*=-1;
    mx+=vmx; my+=vmy; if(mx>185||mx<10)vmx*=-1; if(my>140||my<10)vmy*=-1;
    if(d1)d1.setAttribute('transform',`translate(${dx},${dy})`);
    if(d2)d2.setAttribute('transform',`translate(${mx},${my})`);
    if(telaAtual==='t-mapa') requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

window.addEventListener('load',()=>{
  aplicarDadosMotorista();
  setTimeout(()=>{const s=document.getElementById('splash'); s.classList.add('hide'); setTimeout(()=>s.remove(),500);},2000);
});
document.querySelectorAll('.tela').forEach(t=>{if(!t.classList.contains('ativa'))t.style.display='none'});

/* ════════════════════════════════════════════════════════════════
   GOOGLE MAPS (opcional) — cole sua chave abaixo, entre as aspas
   ════════════════════════════════════════════════════════════════ */
const GOOGLE_MAPS_API_KEY = "";
const PAULO_AFONSO_COORDS = { lat: -9.3989, lng: -38.2178 };
let _mapsInitTentado = false;
function carregarGoogleMapsSeConfigurado(){
  if(_mapsInitTentado) return;
  _mapsInitTentado = true;
  if(!GOOGLE_MAPS_API_KEY){ return; }
  const script = document.createElement('script');
  script.src = `https://maps.googleapis.com/maps/api/js?key=${GOOGLE_MAPS_API_KEY}&callback=initGoogleMapReal`;
  script.async = true;
  document.head.appendChild(script);
}
function initGoogleMapReal(){
  const real = document.getElementById('googleMapReal');
  const ilustrativo = document.getElementById('mapaIlustrativo');
  if(!real) return;
  real.style.display='block'; if(ilustrativo) ilustrativo.style.display='none';
  const map = new google.maps.Map(real, {
    center: PAULO_AFONSO_COORDS, zoom: 14, disableDefaultUI: true, zoomControl: true,
    styles: [
      { elementType: "geometry", stylers: [{ color: "#122E3B" }] },
      { elementType: "labels.text.stroke", stylers: [{ color: "#06141B" }] },
      { elementType: "labels.text.fill", stylers: [{ color: "#7FA0A8" }] },
      { featureType: "road", elementType: "geometry", stylers: [{ color: "#21495a" }] },
      { featureType: "water", elementType: "geometry", stylers: [{ color: "#0D2430" }] },
      { featureType: "poi", elementType: "geometry", stylers: [{ color: "#173a49" }] }
    ]
  });
  new google.maps.Marker({
    position: PAULO_AFONSO_COORDS, map: map,
    label: { text: "Você", color: "#F4A340", fontWeight: "bold", fontSize: "11px" },
    icon: { path: google.maps.SymbolPath.CIRCLE, scale: 8, fillColor: "#F4A340", fillOpacity: 1, strokeWeight: 0 }
  });
}
</script>
</body>
</html>

